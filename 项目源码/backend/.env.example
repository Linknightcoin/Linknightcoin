# ======== 善行天下（Linknightcoin）配置文件 ========
# 复制本文件为 .env，然后填入实际值：
#   cp .env.example .env

# ---- 服务配置 ----
PORT=3000

# ---- 区块链配置 ----
BSC_RPC=https://1rpc.io/bnb
BSC_CHAIN_ID=56

# ---- 运营钱包私钥（链上记录功值必需，请妥善保管）----
PRIVATE_KEY=你的运营钱包私钥

# ---- 智谱AI API Key（善举验证必需）----
ZHIPU_API_KEY=你的智谱AI_API_Key
# 也可使用 DEEPSEEK_API_KEY 变量名，效果相同
# DEEPSEEK_API_KEY=你的智谱AI_API_Key

# ---- 合约地址（BSC 主网，一般无需修改）----
LINK_TOKEN=0xf24411ab56ac52938d27eaa53559d7cd7e122718
MERIT_HALVING=0x37F113BC82db516c3dC378A320EeA3f9639D7271
MERIT_LOTTERY=0x95BD41B8E21470EBE52d371167bC36c6b0D99afF
REWARD_POOL=0x95BD41B8E21470EBE52d371167bC36c6b0D99afF
MERIT_REGISTRY=0x37F113BC82db516c3dC378A320EeA3f9639D7271
SUBMISSION_LIMITER=0xAC51efdc783BbF529b12FCd47997C54bB592c464
FEE_REPURCHASER=0x9df6b4c0f45f3e28c0cc9a74db271929f4ea4651
